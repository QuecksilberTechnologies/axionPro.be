{

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=fullbackup;Username=postgres;Password=1234;SearchPath=axionpro;"
  },

  "FrontEndWebURL": {
    "BaseURL": "http://localhost:4200"
  },

  "FileSettings": {
    "BaseUrl": "https://axionpro-api.onrender.com",
    "RootFolder": "wwwroot/uploads/",
    "TenantFolder": "tenants",
    "DefaultFolder": "defaults",
    "DefaultImage": "defaults/default.png"
  },
  "EmailConfig": {
    "SMTPUserName": "",
    "Secret": ""
  },
  "AWSUploads": {
    "AccesskeyID": "",
    "Secretaccesskey": "",
    "Region": "ap-south-1",
    "BucketName": "axionprodoc"
  },
  "GoogleCloud": {
    "BucketName": "axionpro-teststorage-b59b45113275",
    "BasePath": "uploads"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "JWTSettings": {
    "Secret": "YourVerySecureRandomlyGeneratedKeyHere",
    "Issuer": "axionproApp",
    "Audience": "axionproUsers",
    "TokenLifetime": "00:30:00"
  },

  "AllowedHosts": "*"
}